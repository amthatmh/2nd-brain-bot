{% comment %}
  TRMNL daily workout card — paste into the private plugin's "Half vertical"
  markup tab. Same data source/keys as trmnl_card.liquid (Full). Sections
  stack top/bottom instead of side-by-side to fit the narrower 400px width.
{% endcomment %}

<div style="width:400px;height:480px;background:#fff;color:#000;font-family:'Helvetica Neue',Arial,sans-serif;box-sizing:border-box;padding:16px;display:flex;flex-direction:column;">

  <!-- Title -->
  <div style="display:flex;align-items:baseline;border-bottom:3px solid #000;padding-bottom:6px;">
    <div style="font-size:22px;font-weight:700;letter-spacing:1px;">{{ day_label }}</div>
    <div style="margin-left:auto;font-size:13px;color:#555;">{{ date_label }}</div>
  </div>
  {% if track != "" %}
    <div style="font-size:13px;color:#555;padding-top:2px;">{{ track }}</div>
  {% endif %}

  {% if found != true %}
    <div style="flex:1;display:flex;align-items:center;justify-content:center;font-size:16px;color:#555;text-align:center;">
      No workout programmed for today.
    </div>
  {% else %}

  <div style="flex:1;display:flex;flex-direction:column;gap:10px;padding-top:10px;min-height:0;">

    <!-- Section B -->
    <div style="flex:1;display:flex;flex-direction:column;min-height:0;">
      <div style="font-size:12px;font-weight:700;letter-spacing:1px;border-bottom:1px solid #000;padding-bottom:3px;">SECTION B — STRENGTH</div>
      <div style="padding-top:6px;">
        {% for line in section_b.lines %}
          <div style="font-size:15px;font-weight:600;line-height:1.3;">{{ line }}</div>
        {% endfor %}
      </div>
      {% if section_b.notes.size > 0 %}
        <div style="margin-top:auto;padding-top:6px;">
          {% for note in section_b.notes %}
            <div style="font-size:11px;color:#444;line-height:1.35;">– {{ note }}</div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Section C -->
    <div style="flex:1;display:flex;flex-direction:column;min-height:0;border-top:1px solid #ccc;padding-top:10px;">
      <div style="font-size:12px;font-weight:700;letter-spacing:1px;border-bottom:1px solid #000;padding-bottom:3px;">SECTION C — CONDITIONING</div>
      <div style="padding-top:6px;">
        {% for line in section_c.lines %}
          <div style="font-size:15px;font-weight:600;line-height:1.3;">{{ line }}</div>
        {% endfor %}
      </div>
      {% if section_c.notes.size > 0 %}
        <div style="margin-top:auto;padding-top:6px;">
          {% for note in section_c.notes %}
            <div style="font-size:11px;color:#444;line-height:1.35;">– {{ note }}</div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

  </div>

  {% endif %}
</div>
