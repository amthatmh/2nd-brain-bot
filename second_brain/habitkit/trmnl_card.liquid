{% comment %}
  TRMNL habit tracker card — paste into the private plugin's "Edit Markup".
  Data source: GET /trmnl/habits?token=... (polling strategy).
  Polled JSON keys are available as top-level Liquid variables:
    range_label  day_headers[7]  count
    habits[]{name,icon,days[7],done,streak,today_done}
  800x480, 1-bit e-ink. One habit per row, past 7 days left->right (today = last
  column). Filled dot = done, open dot = missed. Rows share the day columns so a
  weekday reads straight down.
{% endcomment %}

<div style="width:800px;height:480px;background:#fff;color:#000;font-family:'Helvetica Neue',Arial,sans-serif;box-sizing:border-box;padding:22px;display:flex;flex-direction:column;">

  <!-- Title -->
  <div style="display:flex;align-items:baseline;border-bottom:3px solid #000;padding-bottom:8px;">
    <div style="font-size:30px;font-weight:700;letter-spacing:2px;">HABITS</div>
    <div style="margin-left:auto;font-size:16px;color:#555;">Past 7 days · {{ range_label }}</div>
  </div>

  {% if count == 0 %}
    <div style="flex:1;display:flex;align-items:center;justify-content:center;font-size:22px;color:#555;">
      No habits flagged for TRMNL. Tick the “TRMNL” box in Notion.
    </div>
  {% else %}

  <!-- Column headers: only the last (rightmost) dot column is labelled TODAY -->
  <div style="display:flex;align-items:center;padding:8px 0 4px;font-size:11px;font-weight:700;color:#333;letter-spacing:1px;">
    <div style="flex:1;"></div>
    {% for h in day_headers %}
      <div style="width:44px;text-align:center;">{% if forloop.last %}TODAY{% endif %}</div>
    {% endfor %}
    <div style="width:60px;text-align:center;">STREAK</div>
  </div>

  <!-- Habit rows -->
  <div style="flex:1;display:flex;flex-direction:column;">
    {% for habit in habits %}
      <div style="display:flex;align-items:center;flex:1;border-top:1px solid #ccc;">
        <div style="flex:1;display:flex;align-items:center;overflow:hidden;white-space:nowrap;">
          <span style="font-size:22px;font-weight:600;overflow:hidden;text-overflow:ellipsis;">{{ habit.name }}</span>
        </div>
        {% for d in habit.days %}
          <div style="width:44px;text-align:center;font-size:26px;line-height:1;">{% if d == 1 %}●{% else %}○{% endif %}</div>
        {% endfor %}
        <div style="width:60px;text-align:center;font-size:22px;font-weight:700;">{{ habit.streak }}</div>
      </div>
    {% endfor %}
  </div>

  {% endif %}
</div>
