{% comment %}
  TRMNL health coaching card — paste into the private plugin's "Edit Markup".
  Data source: GET /trmnl/health?token=... (polling strategy).
  Polled JSON keys are available as top-level Liquid variables:
    verdict{level,word,arrow,line} activity{score,desc,recommendation}
    steps{today,avg7,week_total} workouts{done,target,trend}
    hrv{value,delta_pct,arrow} rhr{value,delta_pct,arrow}
    sleep{avg7_hours,arrow} day_label
  800x480, 1-bit e-ink. Verdict is triple-encoded: fill + arrow + word.
{% endcomment %}

{% assign lvl = verdict.level %}
{% if lvl == "push" %}
  {% assign bar_bg = "#000" %}{% assign bar_fg = "#fff" %}{% assign bar_border = "#000" %}
{% elsif lvl == "rest" %}
  {% assign bar_bg = "#fff" %}{% assign bar_fg = "#000" %}{% assign bar_border = "#000" %}
{% else %}
  {% assign bar_bg = "repeating-linear-gradient(45deg,#000,#000 2px,#fff 2px,#fff 6px)" %}
  {% assign bar_fg = "#000" %}{% assign bar_border = "#000" %}
{% endif %}

<div style="width:800px;height:480px;background:#fff;color:#000;font-family:'Helvetica Neue',Arial,sans-serif;box-sizing:border-box;padding:22px;display:flex;flex-direction:column;">

  <!-- Verdict bar -->
  <div style="display:flex;align-items:center;border:3px solid {{ bar_border }};background:{{ bar_bg }};height:76px;padding:0 22px;">
    <div style="color:{{ bar_fg }};font-size:40px;font-weight:700;">{{ verdict.arrow }} {{ verdict.word }} TODAY</div>
    {% if lvl == "steady" %}<div style="background:#fff;padding:2px 8px;margin-left:auto;font-size:15px;">{{ day_label }}</div>
    {% else %}<div style="color:{{ bar_fg }};margin-left:auto;font-size:15px;">{{ day_label }}</div>{% endif %}
  </div>
  <div style="font-size:20px;margin:8px 0 14px;">{{ verdict.line }}</div>

  <!-- Body: score + metrics -->
  <div style="display:flex;flex:1;">

    <!-- Left: activity score -->
    <div style="width:250px;border-right:2px solid #000;padding-right:20px;">
      <div style="font-size:14px;letter-spacing:3px;">ACTIVITY SCORE</div>
      <div style="font-size:120px;font-weight:700;line-height:1.1;">
        {% if activity.score %}{{ activity.score }}{% else %}--{% endif %}<span style="font-size:30px;color:#555;">/100</span>
      </div>
      <div style="font-size:18px;margin-top:6px;">{{ activity.desc }}</div>
      <div style="font-size:15px;color:#555;margin-top:10px;">{{ activity.recommendation }}</div>
    </div>

    <!-- Right: steps / workouts-hrv-rhr / sleep -->
    <div style="flex:1;padding-left:24px;display:flex;flex-direction:column;">

      <!-- Steps triple -->
      <div style="font-size:13px;letter-spacing:2px;color:#666;">STEPS</div>
      <div style="display:flex;justify-content:space-between;margin:4px 0 12px;">
        <div><div style="font-size:12px;color:#333;">TODAY</div><div style="font-size:44px;font-weight:700;">{{ steps.today }}</div></div>
        <div><div style="font-size:12px;color:#333;">7-DAY AVG</div><div style="font-size:44px;font-weight:700;">{{ steps.avg7 }}</div></div>
        <div><div style="font-size:12px;color:#333;">THIS WEEK</div><div style="font-size:44px;font-weight:700;">
        <div><div style="font-size:12px;color:#888;">TODAY</div><div style="font-size:44px;font-weight:700;">{{ steps.today }}</div></div>
        <div><div style="font-size:12px;color:#888;">7-DAY AVG</div><div style="font-size:44px;font-weight:700;">{{ steps.avg7 }}</div></div>
        <div><div style="font-size:12px;color:#888;">THIS WEEK</div><div style="font-size:44px;font-weight:700;">
          {% if steps.week_total >= 10000 %}{{ steps.week_total | divided_by: 1000 }}k{% else %}{{ steps.week_total }}{% endif %}
        </div></div>
      </div>

      <!-- Workouts / HRV / RHR -->
      <div style="display:flex;justify-content:space-between;border-top:1px solid #000;padding-top:10px;">
        <div><div style="font-size:13px;letter-spacing:2px;color:#666;">WORKOUTS</div>
          <div style="font-size:28px;font-weight:700;">{{ workouts.done }}/{{ workouts.target }} {{ workouts.trend }}</div></div>
        <div><div style="font-size:13px;letter-spacing:2px;color:#666;">HRV</div>
          <div style="font-size:28px;font-weight:700;">{% if hrv.value %}{{ hrv.value }} <span style="font-size:16px;color:#666;">{{ hrv.delta_pct }}%{{ hrv.arrow }}</span>{% else %}--{% endif %}</div></div>
        <div><div style="font-size:13px;letter-spacing:2px;color:#666;">RHR</div>
          <div style="font-size:28px;font-weight:700;">{% if rhr.value %}{{ rhr.value }} <span style="font-size:16px;color:#666;">{{ rhr.arrow }}</span>{% else %}--{% endif %}</div></div>
      </div>

      <!-- Sleep footer -->
      <div style="margin-top:auto;border-top:2px solid #000;padding-top:10px;background:repeating-linear-gradient(45deg,#000,#000 1px,#fff 1px,#fff 7px);">
        <div style="background:rgba(255,255,255,0.75);padding:6px 8px;">
          <span style="font-size:13px;letter-spacing:2px;color:#666;">SLEEP · 7-DAY AVG</span>
          <span style="font-size:24px;font-weight:700;margin-left:10px;">
            {% if sleep.avg7_hours %}{% assign sh = sleep.avg7_hours | floor %}{% assign sm = sleep.avg7_hours | minus: sh | times: 60 | round %}{{ sh }}h {{ sm }}m {{ sleep.arrow }} <span style="font-size:15px;font-weight:400;color:#666;">/ 7h goal</span>{% else %}no data{% endif %}
          </span>
        </div>
      </div>

    </div>
  </div>
</div>
