{% comment %}
  TRMNL health coaching card. Source of truth — synced to TRMNL by trmnlp.
  Data source: GET /trmnl/health?token=... (polling).
  800x480, TRUE 1-bit e-ink: black + white only.
{% endcomment %}

{% assign lvl = verdict.level %}
{% if lvl == "push" %}
  {% assign bar_bg = "#000" %}{% assign bar_fg = "#fff" %}
{% elsif lvl == "rest" %}
  {% assign bar_bg = "#fff" %}{% assign bar_fg = "#000" %}
{% else %}
  {% assign bar_bg = "repeating-linear-gradient(45deg,#000,#000 3px,#fff 3px,#fff 8px)" %}
  {% assign bar_fg = "#000" %}
{% endif %}

<div style="width:800px;height:480px;background:#fff;color:#000;font-family:'Helvetica Neue',Arial,sans-serif;box-sizing:border-box;padding:22px;display:flex;flex-direction:column;">

  <div style="display:flex;align-items:center;border:3px solid #000;background:{{ bar_bg }};height:76px;padding:0 22px;">
    <div style="color:{{ bar_fg }};font-size:40px;font-weight:800;">{{ verdict.arrow }} {{ verdict.word }} TODAY</div>
    <div style="margin-left:auto;background:#fff;border:2px solid #000;padding:2px 8px;font-size:15px;font-weight:700;">{{ day_label }}</div>
  </div>
  <div style="font-size:21px;font-weight:600;margin:10px 0 14px;">{{ verdict.line }}</div>

  <div style="display:flex;flex:1;">

    <div style="width:250px;border-right:3px solid #000;padding-right:20px;">
      <div style="font-size:14px;letter-spacing:3px;font-weight:700;">ACTIVITY SCORE</div>
      <div style="font-size:120px;font-weight:800;line-height:1.1;">
        {% if activity.score %}{{ activity.score }}{% else %}--{% endif %}<span style="font-size:30px;font-weight:700;">/100</span>
      </div>
      <div style="font-size:18px;font-weight:600;margin-top:6px;">{{ activity.desc }}</div>
      <div style="font-size:16px;margin-top:10px;">{{ activity.recommendation }}</div>
    </div>

    <div style="flex:1;padding-left:24px;display:flex;flex-direction:column;">

      <div style="font-size:13px;letter-spacing:2px;font-weight:700;">STEPS</div>
      <div style="display:flex;justify-content:space-between;margin:4px 0 12px;">
        <div><div style="font-size:12px;font-weight:700;letter-spacing:1px;">TODAY</div><div style="font-size:44px;font-weight:800;">{{ steps.today }}</div></div>
        <div><div style="font-size:12px;font-weight:700;letter-spacing:1px;">7-DAY AVG</div><div style="font-size:44px;font-weight:800;">{{ steps.avg7 }}</div></div>
        <div><div style="font-size:12px;font-weight:700;letter-spacing:1px;">THIS WEEK</div><div style="font-size:44px;font-weight:800;">
          {% if steps.week_total >= 10000 %}{{ steps.week_total | divided_by: 1000 }}k{% else %}{{ steps.week_total }}{% endif %}
        </div></div>
      </div>

      <div style="display:flex;justify-content:space-between;border-top:2px solid #000;padding-top:10px;">
        <div><div style="font-size:13px;letter-spacing:2px;font-weight:700;">WORKOUTS</div>
          <div style="font-size:28px;font-weight:800;">{{ workouts.done }}/{{ workouts.target }} {{ workouts.trend }}</div></div>
        <div><div style="font-size:13px;letter-spacing:2px;font-weight:700;">HRV</div>
          <div style="font-size:28px;font-weight:800;">{% if hrv.value %}{{ hrv.value }} <span style="font-size:16px;font-weight:600;">{{ hrv.delta_pct }}%{{ hrv.arrow }}</span>{% else %}--{% endif %}</div></div>
        <div><div style="font-size:13px;letter-spacing:2px;font-weight:700;">RHR</div>
          <div style="font-size:28px;font-weight:800;">{% if rhr.value %}{{ rhr.value }} <span style="font-size:16px;font-weight:600;">{{ rhr.arrow }}</span>{% else %}--{% endif %}</div></div>
      </div>

      <div style="margin-top:auto;border-top:2px solid #000;padding-top:10px;">
        <span style="font-size:13px;letter-spacing:2px;font-weight:700;">SLEEP · 7-DAY AVG</span>
        <span style="font-size:24px;font-weight:800;margin-left:10px;">
          {% if sleep.avg7_hours %}{% assign sh = sleep.avg7_hours | floor %}{% assign sm = sleep.avg7_hours | minus: sh | times: 60 | round %}{{ sh }}h {{ sm }}m {{ sleep.arrow }} <span style="font-size:15px;font-weight:600;">/ 7h goal</span>{% else %}no data{% endif %}
        </span>
      </div>

    </div>
  </div>
</div>
